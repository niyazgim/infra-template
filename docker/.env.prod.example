# === PROJECT INFO ===
ORG_NAME=your-proj-name
REPOSITORY_NAME=${ORG_NAME}-infra
BUILD_TARGET=prod

# === 
# BACKEND 
# ===
APP_PORT=8080
AUTH_PORT=8081
PROFILE_PORT=8082

# === auth_db microservice ===
AUTH_DB_DRIVER=
AUTH_DB_HOST=
AUTH_DB_PORT=5432
AUTH_DB_NAME=
AUTH_DB_USER=
AUTH_DB_PASSWORD=
AUTH_DB_SSLMODE=require
AUTH_DB_DSN=${AUTH_DB_DRIVER}://${AUTH_DB_USER}:${AUTH_DB_PASSWORD}@${AUTH_DB_HOST}:${AUTH_DB_PORT}/${AUTH_DB_NAME}?sslmode=${AUTH_DB_SSLMODE} 

# === auth microservice ===
JWT_SECRET_KEY=
SMS_PROVIDER_SENDER_NAME=
SMS_PROVIDER_API_URL=
SMS_PROVIDER_API_KEY=

# === profile_db microservice ===
PROFILE_DB_DRIVER=
PROFILE_DB_HOST=
PROFILE_DB_PORT=5432
PROFILE_DB_NAME=
PROFILE_DB_USER=
PROFILE_DB_PASSWORD=
PROFILE_DB_SSLMODE=require
PROFILE_DB_DSN=${PROFILE_DB_DRIVER}://${PROFILE_DB_USER}:${PROFILE_DB_PASSWORD}@${PROFILE_DB_HOST}:${PROFILE_DB_PORT}/${PROFILE_DB_NAME}?sslmode=${PROFILE_DB_SSLMODE} 

# === gin-gonic settings ===
GIN_MODE=release

# === FRONTEND ===
NEXT_PUBLIC_BASE_URL=https://your-proj-name.com
FRONTEND_PORT=3000